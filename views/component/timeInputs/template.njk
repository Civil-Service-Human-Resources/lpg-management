<h3 class="govuk-heading-s event-time-heading">{{ header }}</h3>
<div class="time-inputs">
    <div class="govuk-date-input__item">
        {% set hoursList = firstValue %}
        {% set hours = [] %}

        {% for i in hoursList %}
        {% set hour = hours.push({
                "text": i,
                "value": i,
                "selected": true if firstSelected === i
            }) %}
        {% endfor %}

        {% set hoursLabel %}
            <label class="govuk-label" for="{{name}}-hours">
                <span class="govuk-visually-hidden">{{ header }}</span> {{firstLabel}}
            </label>
        {% endset %}

        {{ govukSelect({
            id: name + "-hours",
            name: name,
            label: {
                html: hoursLabel
            },
            items: hours
        }) }}
    </div>
    <div class="govuk-date-input__item">
        {% set minutesList = secondValue %}
        {% set minutes = [] %}

        {% for j in minutesList %}
            {% set minute = minutes.push({
                "text": j,
                "value": j,
                "selected":  true if secondSelected === j
            }) %}
        {% endfor %}

        {% set minutesLabel %}
            <label class="govuk-label" for="{{name}}-minutes">
                <span class="govuk-visually-hidden">{{ header }}</span> {{secondLabel}}
            </label>
        {% endset %}

        {{ govukSelect({
            id: name + "-minutes",
            name: name,
            label: {
                html: minutesLabel
            },
            items: minutes
        }) }}
    </div>
</div>